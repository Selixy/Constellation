**/Library/PackageCache/

# =========================
# DCC / Blender
# =========================
# Keep source files (.blend, .fbx, textures) versioned.
# Ignore Blender autosave/backup and temp files.
*.blend1
*.blend2
*.blend@*
*.blend~
*.fbx.tmp
*.tmp

# Common DCC cache folders
**/Cache/
**/cache/
**/Caches/

